---
layout: base.njk
title: Contact
isHome: false
permalink: /contact/index.html
---
<div class="show-title">
  <h1>Contact</h1>
</div>
<div class="show-rule"></div>

<div class="section" style="padding-top:50px;">
  <div style="max-width:560px; margin:0 auto; font-size:1.15rem; line-height:1.9;">
    <p>
      <strong>{{ site.contact_nom_diffusion }}</strong><br>
      {{ site.contact_role_diffusion }}<br>
      <a href="mailto:{{ site.contact_email_diffusion }}">{{ site.contact_email_diffusion }}</a><br>
      {{ site.contact_tel_diffusion }}
    </p>

    <p style="margin-top:30px;">
      <strong>{{ site.titre }}</strong><br>
      {{ site.contact_adresse }}<br>
      {{ site.contact_tel }}<br>
      <a href="mailto:{{ site.contact_email_general }}">{{ site.contact_email_general }}</a>
    </p>

    <p style="margin-top:30px;">
      <a href="{{ site.facebook_url }}" class="social-icon contact-social">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z"/></svg>
        <span>Suivre sur Facebook</span>
      </a>
    </p>
  </div>
</div>
