---
layout: base.njk
title: Accueil
isHome: true
---
<div class="hero-photo-wrap">
  <div class="hero-photo" role="img" aria-label="Photographie du spectacle à la une">
    {% if site.photo_accueil %}
      <img src="{{ site.photo_accueil | url }}" alt="Photographie à la une">
    {% else %}
      <span class="caption">Photo à la une</span>
    {% endif %}
  </div>
</div>

<blockquote>
  « {{ site.citation_texte }} »
  <span class="quote-author">{{ site.citation_auteur | upper }}</span>
</blockquote>

<section class="section" id="spectacles">
  <div class="section-head">
    <h2>Les Spectacles</h2>
    <div class="rule"></div>
  </div>
  <div class="bill-grid">
    {% for spectacle in collections.spectacles %}
    <a class="bill-card" href="{{ spectacle.url | url }}">
      <h3>{{ spectacle.data.title }}</h3>
      <p>{{ spectacle.data.accroche }}</p>
    </a>
    {% endfor %}
  </div>
</section>

<section class="section" id="agenda">
  <div class="section-head">
    <h2>Agenda</h2>
    <div class="rule"></div>
  </div>

  {% if collections.datesAvenir.length > 0 %}
    <div class="agenda-ticker-wrap">
      <div class="agenda-ticker">
        {% for d in collections.datesAvenir %}
          <span class="agenda-ticker-item">
            📅 {{ d.data.date | dateFr }} — <strong>{{ d.data.spectacle }}</strong> — {{ d.data.lieu }}{% if d.data.ville %}, {{ d.data.ville }}{% endif %}
          </span>
        {% endfor %}
        {% for d in collections.datesAvenir %}
          <span class="agenda-ticker-item" aria-hidden="true">
            📅 {{ d.data.date | dateFr }} — <strong>{{ d.data.spectacle }}</strong> — {{ d.data.lieu }}{% if d.data.ville %}, {{ d.data.ville }}{% endif %}
          </span>
        {% endfor %}
      </div>
    </div>
    <p style="text-align:center; margin-top:24px;">
      <a class="btn" href="{{ '/agenda/' | url }}">Voir toutes les dates</a>
    </p>
  {% else %}
    <p style="text-align:center; max-width:600px; margin:0 auto;">{{ site.agenda_texte }}</p>
  {% endif %}
</section>
