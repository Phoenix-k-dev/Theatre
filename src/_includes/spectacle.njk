---
layout: base.njk
isHome: false
---
<div class="show-title">
  <h1>{{ title }}</h1>
</div>
<div class="show-rule"></div>

<div class="show-body show-body--with-photo{% if photo_position == 'gauche' %} show-body--photo-left{% endif %}">
  {% if photo and photo_position == 'gauche' %}
  <div class="show-photo show-photo--{{ photo_ratio or 'portrait' }}" role="img" aria-label="Photographie du spectacle {{ title }}">
    <img src="{{ photo | url }}" alt="Photographie du spectacle {{ title }}">
  </div>
  {% endif %}

  <div class="show-text">
    <div class="facts">
      {{ facts | nl2br | safe }}
    </div>

    <div class="description">
      {{ content | safe }}
      {% if dossier %}
        <a class="dossier-btn" href="{{ dossier }}">Dossier de Diffusion</a>
      {% endif %}
    </div>

    {% if credits %}
    <div class="credits">
      {{ credits | nl2br | safe }}
    </div>
    {% endif %}
  </div>

  {% if photo and photo_position != 'gauche' %}
  <div class="show-photo show-photo--{{ photo_ratio or 'portrait' }}" role="img" aria-label="Photographie du spectacle {{ title }}">
    <img src="{{ photo | url }}" alt="Photographie du spectacle {{ title }}">
  </div>
  {% endif %}
</div>

{% if video %}
<div class="show-body" style="padding-top:60px;">
  <div class="video-embed">
    <iframe
      src="{{ video | youtubeEmbed }}"
      title="Vidéo du spectacle {{ title }}"
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen>
    </iframe>
  </div>
</div>
{% endif %}
