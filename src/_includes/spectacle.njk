---
layout: base.njk
isHome: false
---
<div class="show-title">
  <h1>{{ title }}</h1>
</div>
<div class="show-rule"></div>

{% if mise_en_page == 'fiche-double' %}
  {# Variante : facts en haut, puis photo1+synopsis, puis texte centré (police graphique), puis photo2+texte #}
  <div class="show-body">
    <div class="facts">
      {{ facts | nl2br | safe }}
    </div>
  </div>

  {% if photo2 %}
  <div class="show-body show-body--with-photo" style="padding-top:36px;">
    <div class="show-text">
      <div class="description">
        {{ synopsis | nl2br | safe }}
      </div>
    </div>
    {% if photo %}
    <div class="show-photo-stack">
      <div class="show-photo-naturel">
        <img src="{{ photo | url }}" alt="{{ title }} - Photo principale">
      </div>
    </div>
    {% endif %}
  </div>

  {% if note_intention %}
  <div class="section" style="padding-top:50px;">
    <div class="note-intention">
      {{ note_intention | nl2br | safe }}
    </div>
  </div>
  {% endif %}

  <div class="show-body show-body--with-photo show-body--photo-left" style="padding-top:20px;">
    <div class="show-photo-stack">
      <div class="show-photo-naturel">
        <img src="{{ photo2 | url }}" alt="{{ title }} - Deuxième photo">
      </div>
    </div>
    <div class="show-text">
      <div class="description">
        {{ content | safe }}
        {% if dossier %}
          <a class="dossier-btn" href="{{ dossier }}">Dossier de Diffusion</a>
        {% endif %}
        {% if revue_presse %}
          <a class="dossier-btn" href="{{ revue_presse }}">Revue de Presse</a>
        {% endif %}
      </div>
      {% if credits %}
      <div class="credits">
        {{ credits | nl2br | safe }}
      </div>
      {% endif %}
    </div>
  </div>
  {% else %}
  {# Pas de 2e photo : une seule grille, chaque colonne empile son propre contenu #}
  <div class="show-body show-body--with-photo" style="padding-top:36px;">
    <div class="show-text">
      <div class="description">
        {{ synopsis | nl2br | safe }}
      </div>
      {% if dossier %}
        <a class="dossier-btn" href="{{ dossier }}">Dossier de Diffusion</a>
      {% endif %}
      {% if revue_presse %}
        <a class="dossier-btn" href="{{ revue_presse }}">Revue de Presse</a>
      {% endif %}
      {% if credits %}
      <div class="credits">
        {{ credits | nl2br | safe }}
      </div>
      {% endif %}
    </div>

    <div class="show-photo-col">
      {% if photo %}
      <div class="show-photo-stack">
        <div class="show-photo-naturel">
          <img src="{{ photo | url }}" alt="{{ title }} - Photo principale">
        </div>
      </div>
      {% endif %}
      <div class="description" style="margin-top:40px;">
        {{ content | safe }}
      </div>
    </div>
  </div>

  {% if note_intention %}
  <div class="section" style="padding-top:50px;">
    <div class="note-intention">
      {{ note_intention | nl2br | safe }}
    </div>
  </div>
  {% endif %}
  {% endif %}

  {% if affiche %}
  <div class="section" style="padding-top:0;">
    <div class="show-affiche">
      <img src="{{ affiche | url }}" alt="Affiche du spectacle {{ title }}">
    </div>
  </div>
  {% endif %}

{% elif mise_en_page == 'fiche' %}
  {# Variante : fiche technique + petite photo en haut, texte en pleine largeur en dessous #}
  <div class="show-body show-body--fiche">
    <div class="facts">
      {{ facts | nl2br | safe }}
    </div>
    {% if photo %}
    <div class="show-photo show-photo--{{ photo_ratio or 'portrait' }} show-photo--small" role="img" aria-label="Photographie du spectacle {{ title }}">
      <img src="{{ photo | url }}" alt="Photographie du spectacle {{ title }}">
    </div>
    {% endif %}
  </div>

  <div class="section" style="padding-top:40px;">
    <div class="description description--full">
      {{ content | safe }}
      {% if dossier %}
        <a class="dossier-btn" href="{{ dossier }}">Dossier de Diffusion</a>
      {% endif %}
      {% if revue_presse %}
        <a class="dossier-btn" href="{{ revue_presse }}">Revue de Presse</a>
      {% endif %}
    </div>
    {% if credits %}
    <div class="credits">
      {{ credits | nl2br | safe }}
    </div>
    {% endif %}
  </div>

  {% if affiche %}
  <div class="section" style="padding-top:0;">
    <div class="show-affiche">
      <img src="{{ affiche | url }}" alt="Affiche du spectacle {{ title }}">
    </div>
  </div>
  {% endif %}

{% else %}
  {# Variante standard : photo et texte côte à côte #}
  <div class="show-body">
    <div class="facts">
      {{ facts | nl2br | safe }}
    </div>
  </div>

  <div class="show-body show-body--with-photo{% if photo_position == 'gauche' %} show-body--photo-left{% endif %}" style="padding-top:36px;">
    {% if photo and photo_position == 'gauche' %}
    <div class="show-photo show-photo--{{ photo_ratio or 'portrait' }}" role="img" aria-label="Photographie du spectacle {{ title }}">
      <img src="{{ photo | url }}" alt="Photographie du spectacle {{ title }}">
    </div>
    {% endif %}

    <div class="show-text">
      <div class="description">
        {{ content | safe }}
        {% if dossier %}
          <a class="dossier-btn" href="{{ dossier }}">Dossier de Diffusion</a>
        {% endif %}
        {% if revue_presse %}
          <a class="dossier-btn" href="{{ revue_presse }}">Revue de Presse</a>
        {% endif %}
      </div>

      {% if credits %}
      <div class="credits">
        {{ credits | nl2br | safe }}
      </div>
      {% endif %}
    </div>

    {% if photo and photo_position != 'gauche' %}
    <div class="show-photo-stack">
      {% if photo2 %}
      <div class="show-photo-naturel">
        <img src="{{ photo2 | url }}" alt="Photographie du spectacle {{ title }}">
      </div>
      {% endif %}
      <div class="show-photo-naturel">
        <img src="{{ photo | url }}" alt="Photographie du spectacle {{ title }}">
      </div>
    </div>
    {% endif %}
  </div>

  {% if affiche %}
  <div class="section" style="padding-top:0;">
    <div class="show-affiche">
      <img src="{{ affiche | url }}" alt="Affiche du spectacle {{ title }}">
    </div>
  </div>
  {% endif %}
{% endif %}

{% if video %}
<div class="show-body" style="padding-top:60px;">
  <div class="video-embed">
    <iframe
      src="{{ video | youtubeEmbed }}"
      title="Vidéo du spectacle {{ title }}"
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen>
    </iframe>
  </div>
</div>
{% endif %}

{% if image_bas %}
<div class="section" style="padding-top:0;">
  <div class="show-affiche">
    <img src="{{ image_bas | url }}" alt="Image supplémentaire — {{ title }}">
  </div>
</div>
{% endif %}
