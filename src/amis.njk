layout: base.njk
title: Les Amis des chiffons et d'ailleurs
isHome: false
permalink: /les-amis-des-chiffons-et-dailleurs/index.html
---
<div class="show-title">
  <h1>Les Amis des chiffons et d'ailleurs</h1>
</div>
<div class="show-rule"></div>

<div class="show-body show-body--with-photo">
  <div class="show-text">
    <ul class="amis-list">
      {% for ami in site.amis_liste %}
        <li>
          {% if ami.lien %}
            <a href="{{ ami.lien }}" target="_blank" rel="noopener" class="amis-nom">{{ ami.nom }}</a>
          {% else %}
            <strong class="amis-nom">{{ ami.nom }}</strong>
          {% endif %}
          <br>
          {{ ami.role }}
        </li>
      {% endfor %}
    </ul>
  </div>

  <div class="show-photo amis-photo" role="img" aria-label="Portrait de groupe de la compagnie">
    <img src="{{ '/assets/img/amis.jpg' | url }}" alt="Portrait de groupe de la compagnie">
  </div>
</div>
